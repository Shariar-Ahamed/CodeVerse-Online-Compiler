rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ১. চ্যালেঞ্জ রিড করার পারমিশন সবার জন্য, কিন্তু রাইট/এডিট করতে পারবে শুধুমাত্র এডমিনরা
    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ২. সাবমিশন সেভ করার পারমিশন (লগইন করা ইউজারদের জন্য)
    match /submissions/{submissionId} {
      allow read, write: if request.auth != null;
    }
    
    // ৩. ইউজার স্কোর ও লিডারবোর্ডের পারমিশন
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // পূর্বের ইউজার নোটস ও workspaces সাবকালেকশন সুরক্ষিত রাখা
      match /{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      }
    }

    // ৪. টেম্পোরারি ওটিপি স্টোরেজ (রেজিস্ট্রেশনের সময় লগইন ছাড়া ওটিপি রিড/রাইট করার পারমিশন)
    match /temp_otps/{email} {
      allow read, write: if true;
    }

    // ৫. কন্টাক্ট মেসেজের পারমিশন (যেকোনো ভিজিটর মেসেজ পাঠাতে পারবে, কিন্তু দেখতে ও ডিলিট করতে পারবে শুধু এডমিন)
    match /contacts/{contactId} {
      allow create: if true; 
      allow read, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
